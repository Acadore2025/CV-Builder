{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/builder", "destination": "/builder/index.html" },
    { "source": "/analyser", "destination": "/analyser/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    },
    {
      "source": "/builder",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    },
    {
      "source": "/analyser",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}
